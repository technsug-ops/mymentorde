{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "minify:js": "node scripts/minify-static.mjs js",
        "minify:static": "node scripts/minify-static.mjs all",
        "build:prod": "npm run build && npm run minify:static",
        "e2e:install": "npx playwright install chromium",
        "e2e:student": "playwright test tests/e2e/student-smoke.spec.js",
        "e2e:guest": "playwright test tests/e2e/guest-smoke.spec.js",
        "e2e:dealer": "playwright test tests/e2e/dealer-smoke.spec.js",
        "e2e:senior": "playwright test tests/e2e/senior-smoke.spec.js",
        "e2e:manager": "playwright test tests/e2e/manager-smoke.spec.js",
        "e2e:marketing": "playwright test tests/e2e/marketing-smoke.spec.js",
        "e2e:all": "playwright test tests/e2e/",
        "e2e:dana": "playwright test --config=playwright.dana.config.js",
        "test:e2e": "playwright test tests/e2e/"
    },
    "devDependencies": {
        "@playwright/test": "^1.52.0",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "dotenv": "^17.3.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "terser": "^5.46.1",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@alpinejs/collapse": "^3.15.11",
        "@alpinejs/focus": "^3.15.11",
        "@alpinejs/persist": "^3.15.11",
        "@vitejs/plugin-react": "^5.1.4",
        "alpinejs": "^3.15.11",
        "lucide-react": "^0.575.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    }
}
