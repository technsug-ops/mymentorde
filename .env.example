APP_NAME="${BRAND_NAME}"

# ════════════════════════════════════════════════════════════════════
# WHITE-LABEL BRAND AYARLARI
# Yeni bir kurulumda sadece bu blok değiştirilir, kod değişmez.
# ════════════════════════════════════════════════════════════════════

# ── Temel kimlik ────────────────────────────────────────────────────
BRAND_NAME=MentorDE
BRAND_LEGAL_NAME="MentorDE Eğitim Danışmanlığı"
BRAND_SHORT_NAME=MentorDE
BRAND_TAGLINE="Almanya Eğitim Danışmanlığı"
BRAND_ACCENT=DE

# ── Logo & favicon (URL veya /storage/brand/... path) ───────────────
BRAND_LOGO_URL=
BRAND_LOGO_PATH=
BRAND_LOGO_HEIGHT=40
BRAND_FAVICON_URL=/favicon.ico

# ── İletişim ─────────────────────────────────────────────────────────
BRAND_EMAIL=info@mentorde.com
BRAND_SUPPORT_EMAIL=destek@mentorde.com
BRAND_PHONE=
BRAND_ADDRESS=
BRAND_WEBSITE="${APP_URL}"

# ── Hukuki ──────────────────────────────────────────────────────────
BRAND_COMPANY_NO=
BRAND_TAX_ID=
BRAND_KVKK_URL=
BRAND_TERMS_URL=
BRAND_PRIVACY_URL=

# ── Sosyal medya (opsiyonel) ────────────────────────────────────────
BRAND_INSTAGRAM=
BRAND_TWITTER=
BRAND_YOUTUBE=
BRAND_LINKEDIN=
BRAND_TIKTOK=
BRAND_FACEBOOK=

# ── Tema renkleri (opsiyonel — Manager panelden DB override eder) ───
BRAND_COLOR_PRIMARY=#2563eb
BRAND_COLOR_PRIMARY_2=#1d4ed8
BRAND_COLOR_SUCCESS=#16a34a
BRAND_COLOR_WARNING=#d97706
BRAND_COLOR_DANGER=#dc2626

# ════════════════════════════════════════════════════════════════════

APP_ENV=local
APP_KEY=
# Production'da mutlaka false yapın: APP_DEBUG=false
APP_DEBUG=false
APP_URL=http://localhost
MANAGER_NAME="MentorDE Manager"
MANAGER_EMAIL=manager@mentorde.local
# Şifreler .env.example'a yazılmaz. php artisan db:seed ile dev şifresi oluşturulur.
# MANAGER_PASSWORD=  ← buraya yazmayın
MARKETING_ADMIN_EMAIL=omer@mentorde.local
MARKETING_STAFF1_EMAIL=sule@mentorde.local
MARKETING_STAFF2_EMAIL=merve@mentorde.local

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Production'da warning veya error kullanın: LOG_LEVEL=warning
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Production'da true yapın: SESSION_ENCRYPT=true
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production'da true yapın (HTTPS zorunlu): SESSION_SECURE_COOKIE=true
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Production'da Redis kullanın: QUEUE_CONNECTION=redis
# Hostinger database queue için: php artisan queue:table && php artisan migrate
QUEUE_CONNECTION=database
# NOT: route:cache için php -d memory_limit=256M artisan route:cache kullanın

# Production'da Redis kullanın: CACHE_STORE=redis
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Production'da SMTP kullanın: MAIL_MAILER=smtp
MAIL_MAILER=log
MAIL_SCHEME=null
# Production SMTP örneği: MAIL_HOST=smtp.mailgun.org veya smtp.sendgrid.net
MAIL_HOST=127.0.0.1
# Production SMTP portu: 587 (TLS) veya 465 (SSL)
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="${BRAND_EMAIL}"
MAIL_FROM_NAME="${BRAND_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

MKTG_EXTERNAL_SYNC_DAYS=7

MKTG_META_ENABLED=false
MKTG_META_API_VERSION=v21.0
MKTG_META_AD_ACCOUNT_ID=
MKTG_META_ACCESS_TOKEN=

MKTG_GA4_ENABLED=false
MKTG_GA4_PROPERTY_ID=
MKTG_GA4_CREDENTIALS=

MKTG_GOOGLE_ADS_ENABLED=false
MKTG_GOOGLE_ADS_CUSTOMER_ID=
MKTG_GOOGLE_ADS_LOGIN_CUSTOMER_ID=
MKTG_GOOGLE_ADS_DEVELOPER_TOKEN=
MKTG_GOOGLE_ADS_ACCESS_TOKEN=

MKTG_TIKTOK_ENABLED=false
MKTG_TIKTOK_ADVERTISER_ID=
MKTG_TIKTOK_ACCESS_TOKEN=

MKTG_LINKEDIN_ENABLED=false
MKTG_LINKEDIN_AD_ACCOUNT_ID=
MKTG_LINKEDIN_ACCESS_TOKEN=
MKTG_LINKEDIN_REFRESH_TOKEN=
MKTG_LINKEDIN_CLIENT_ID=
MKTG_LINKEDIN_CLIENT_SECRET=

MKTG_INSTAGRAM_ENABLED=false
MKTG_INSTAGRAM_USER_ID=
MKTG_INSTAGRAM_ACCESS_TOKEN=

AI_WRITER_ENABLED=false
AI_WRITER_PROVIDER=openai_compatible
AI_WRITER_BASE_URL=https://api.openai.com/v1
AI_WRITER_API_KEY=
AI_WRITER_MODEL=gpt-4o-mini
AI_WRITER_TIMEOUT=30

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=mentorde_verify
WHATSAPP_API_VERSION=v19.0

# Tenor GIF API (used in emoji/GIF picker)
TENOR_API_KEY=

VITE_APP_NAME="${APP_NAME}"

# Stripe Ödeme Gateway
STRIPE_KEY=pk_test_xxxx
STRIPE_SECRET=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
